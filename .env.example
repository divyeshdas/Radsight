# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=RadSight
APP_VERSION=1.0.0
DEBUG=true

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://radsight_user:radsight_pass@mongodb:27017/radsight?authSource=admin
MONGODB_DB_NAME=radsight
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=5

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=radsight_redis_pass
REDIS_DB=0
REDIS_CACHE_TTL=3600
REDIS_EMBEDDING_TTL=86400

# ─── AI Services ──────────────────────────────────────────────────────────────
BIOBERT_MODEL=dmis-lab/biobert-base-cased-v1.2
CLINICALBERT_MODEL=emilyalsentzer/Bio_ClinicalBERT
SENTENCE_BERT_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
SCISPACY_MODEL=en_core_sci_md

# ─── FAISS ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./faiss_index/radsight.index
FAISS_DIMENSION=768
FAISS_NLIST=100
FAISS_NPROBE=10

# ─── OCR ──────────────────────────────────────────────────────────────────────
OCR_LANG=en
OCR_USE_GPU=false
OCR_BATCH_SIZE=4

# ─── Analytics ────────────────────────────────────────────────────────────────
PROPHET_SEASONALITY_MODE=additive
ANOMALY_CONTAMINATION=0.05
TREND_WINDOW_DAYS=30

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,txt,png,jpg,jpeg,tiff

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://radsight.vercel.app

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=RadSight
